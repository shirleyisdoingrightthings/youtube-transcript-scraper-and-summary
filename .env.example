# youtube-transcript.io API key
# Sign up at https://www.youtube-transcript.io — free plan: 20 videos/month
# Copy only the token part (without "Basic ")
YOUTUBE_TRANSCRIPT_API_KEY=your_token_here

# Notion Integration credentials
# 1. Create an integration at https://www.notion.so/profile/integrations
# 2. Copy the "Internal Integration Secret" here
NOTION_API_KEY=ntn_your_key_here

# The ID of the Notion database to upload articles to
# Open the database in Notion → copy the 32-char ID from the URL
NOTION_DATABASE_ID=your_database_id_here
